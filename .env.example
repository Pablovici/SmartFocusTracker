# ============================================================
# GOOGLE CLOUD
# ============================================================
GCP_PROJECT_ID=your-project-id
GCP_DATASET_ID=weather_monitor
GOOGLE_APPLICATION_CREDENTIALS=./gcp_service_account.json

# ============================================================
# BIGQUERY — TABLE NAMES
# ============================================================
BQ_TABLE_INDOOR=indoor_readings
BQ_TABLE_OUTDOOR=outdoor_weather
BQ_TABLE_SESSIONS=work_sessions
BQ_TABLE_ALERTS=alerts_log

# ============================================================
# FLASK
# ============================================================
PORT=8080
FLASK_ENV=development
MIDDLEWARE_URL=

# ============================================================
# OPENWEATHERMAP
# Get your free API key at openweathermap.org
# Note: key takes up to 2 hours to activate after creation
# ============================================================
OPENWEATHER_API_KEY=your-openweathermap-key
OPENWEATHER_CITY=Lausanne
OPENWEATHER_UNITS=metric

# ============================================================
# GEMINI (LLM)
# Get your free API key at aistudio.google.com
# ============================================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ============================================================
# SPEECH (uses same GCP credentials as BigQuery)
# Enable APIs in Google Cloud Console:
# - Cloud Text-to-Speech API
# - Cloud Speech-to-Text API
# ============================================================
SPEECH_LANGUAGE=en-US
TTS_VOICE=en-US-Standard-C

# ============================================================
# DEVICE (copied manually into device_a/config.py)
# ============================================================
WIFI_SSID_1=your-home-wifi
WIFI_PASSWORD_1=your-home-password
WIFI_SSID_2=iot-unil
WIFI_PASSWORD_2=
# TODO: add iot-unil password when available
NTP_UTC_OFFSET=2
SENSOR_INTERVAL_SECONDS=60