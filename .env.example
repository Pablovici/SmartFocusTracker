# === GCP ===
GCP_PROJECT_ID=smart-focus-tracker
GCP_DATASET_ID=focus_tracker_data
GOOGLE_APPLICATION_CREDENTIALS=./gcp_service_account.json

# === BigQuery — Tables ===
BQ_TABLE_SENSORS=sensor_readings
BQ_TABLE_SESSIONS=focus_sessions
BQ_TABLE_WEATHER=weather_history

# === Flask Middleware ===
FLASK_PORT=8080
FLASK_ENV=development

# === OpenWeatherMap ===
OPENWEATHER_API_KEY=your_api_key_here
OPENWEATHER_CITY=Lausanne
OPENWEATHER_UNITS=metric

# === OpenAI / Gemini (LLM) ===
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4o-mini

# === Google Speech ===
GOOGLE_TTS_LANGUAGE=fr-FR
GOOGLE_STT_LANGUAGE=fr-FR

# === M5Stack Device ===
MIDDLEWARE_URL=http://your-cloud-run-url
WIFI_SSID=your_wifi_name
WIFI_PASSWORD=your_wifi_password